# app
NEXT_PUBLIC_API_URL=
APP_ENV=development

# demo deployment only
# Set both demo flags to true only for https://demo.hexoo.eu.
# IS_DEMO gates destructive server-side reset operations.
IS_DEMO=false
# NEXT_PUBLIC_IS_DEMO is safe for non-sensitive UI display only.
NEXT_PUBLIC_IS_DEMO=false
# Required by /api/demo/reset. Use a long random value in Vercel.
CRON_SECRET=replace-with-long-random-secret
DEMO_USER_EMAIL=demo@hexoo.eu
DEMO_USER_PASSWORD=replace-with-demo-password
DEMO_USER_DISPLAY_NAME=Demo User

# supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# optional alias used in some deployments
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# google reCAPTCHA
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# moderation
OPENAI_API_KEY=
